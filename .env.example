VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only. Never expose in browser:
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# QPAY_CLIENT_ID=
# QPAY_CLIENT_SECRET=
# QPAY_INVOICE_CODE=
# APP_URL=

# Controlled Gemini test script (scripts/test-gemini-generation.mjs).
# Set in local terminal session ONLY — never in .env.local.
# ENABLE_GEMINI_TEST_GENERATION=false
# GEMINI_TEST_MODEL=gemini-2.5-flash-image
# GEMINI_TEST_OUTPUT_COUNT=1
#
# Optional: enables Supabase DB record + storage upload from the test script.
# SUPABASE_URL=https://noxuklmhcafelkwatnhg.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TEST_USER_ID=<your-user-uuid-from-profiles-table>
# SUPABASE_TEST_PRODUCT_ID=22222222-2222-4222-8222-222222222201
